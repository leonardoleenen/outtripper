{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "types": ["jest", "node"]
  },
  "compileOnSave": true,
  "include": [
    "test/**/*.test.ts",
    "src",
    "node_modules/@types"
  ],
  "exclude": [
    "tmp",
    "dist",
    "test",
    "node_modules"
  ]
}
